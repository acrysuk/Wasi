# Wasi Mutual - .htaccess optimizado para DonWeb
# Con Cloudflare, algunas reglas se manejan desde su panel

# Habilitar compresión GZIP
<IfModule mod_deflate.c>
    # Compresión para Cloudflare + DonWeb
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    
    # Excluir navegadores antiguos
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
    
    # Excluir proxies
    Header append Vary User-Agent
</IfModule>

# Cacheo de navegador (Cloudflare ya maneja cache, pero esto es adicional)
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Por defecto: 1 hora
    ExpiresDefault "access plus 1 hour"
    
    # HTML: 2 horas (más frecuente porque puede cambiar)
    ExpiresByType text/html "access plus 2 hours"
    
    # CSS y JS: 1 mes
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/x-javascript "access plus 1 month"
    
    # Imágenes: 6 meses
    ExpiresByType image/jpeg "access plus 6 months"
    ExpiresByType image/png "access plus 6 months"
    ExpiresByType image/gif "access plus 6 months"
    ExpiresByType image/webp "access plus 6 months"
    ExpiresByType image/svg+xml "access plus 6 months"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # Fuentes: 1 año
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    
    # PDF y documentos: 1 mes
    ExpiresByType application/pdf "access plus 1 month"
</IfModule>

# Redirección WWW a NON-WWW (recomendado para SEO)
# IMPORTANTE: Configura esto según tu preferencia
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Opción A: Redirigir www a non-www (RECOMENDADO)
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]
    
    # Opción B: Redirigir HTTP a HTTPS (si Cloudflare no lo hace)
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Manejo de URLs amigables (si no usas extensiones .html)
# Descomenta si quieres URLs sin .html

#<IfModule mod_rewrite.c>
